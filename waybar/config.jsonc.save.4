{
  "layer": "top",
  "position": "top",
  "height": 30,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,

  "modules-left": [
    "custom/clock",
    "custom/vremya",
    "hyprland/language"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "custom/notification",
    "pulseaudio",
    "network",
    "battery"
  ],

  // ===== DATE =====

"custom/clock": {
  "exec": "date '+ï„³ %A %d.%m'",
  "tooltip": true
},

"custom/vremya": {
  "exec": "date '+ï€— %H:%M'" ,
  "interval": 60,
  "tooltip": true
},

  // ===== TASKBAR =====
  "hyprland/language": {
    "format": "{}",
    "format-uk": "",
    "format-en": "English",
  },

  // ===== WORKSPACES =====
  "hyprland/workspaces": {
    "format": "{id}",
    "sort-by-number": true,
    "on-click": "activate"
  },

  // ===== AUDIO =====
  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-muted": "َ°‌ں Muted",
    "scroll-step": 5,
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "format-icons": {
      "default": ["َ°•؟", "َ°–€", "َ°•¾"]
    }
  },

  // ===== NETWORK =====
  "network": {
    "format-wifi": "ï‡«  {signalStrength}%",
    "format-ethernet": "َ°ˆ€ LAN",
    "format-disconnected": "َ°¤­",
    "on-click": "kitty nmtui",
    "tooltip": true
  },

  "custom/notification": {
    "tooltip": true,
    "format": "<span size='16pt'>{icon}</span>",
    "format-icons": {
      "notification": "َ±…« ",
      "none": "َ°‚œ ",
      "dnd-notification": "َ°‚  ",
      "dnd-none": "َ°ھ“ ",
      "inhibited-notification": "َ°‚› ",
      "inhibited-none": "َ°ھ‘ ",
      "dnd-inhibited-notification": "َ°‚› ",
      "dnd-inhibited-none": "َ°ھ‘ "
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
  },
  
  // ===== BATTERY =====
  "battery": {
    "format": "{icon} {capacity}%",
    "format-charging": "َ°‚„ {capacity}%",
    "states": {
      "warning": 30,
      "critical": 15
    },
    "format-icons": [
      "َ°پ؛","َ°پ»","َ°پ¼","َ°پ½","َ°پ¾",
      "َ°پ؟","َ°‚€","َ°‚پ","َ°‚‚","َ°پ¹"
    ]
  }
}
